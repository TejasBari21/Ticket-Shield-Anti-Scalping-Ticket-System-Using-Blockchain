{
    "name": "fair-pass-backend",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "start": "hardhat node",
        "compile": "hardhat compile",
        "deploy": "hardhat run scripts/deploy.ts",
        "deploy:localhost": "hardhat run scripts/deploy.ts --network localhost",
        "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
        "test": "hardhat test",
        "update-abi": "node updateAbi.cjs",
        "postinstall": "node -e \"require('fs').rmSync('./node_modules/@nomicfoundation/hardhat-ethers/src', {recursive: true, force: true})\""
    },
    "dependencies": {
        "dotenv": "^17.3.1"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-toolbox": "^4.0.0",
        "@openzeppelin/contracts": "^4.9.3",
        "hardhat": "^2.22.0"
    }
}
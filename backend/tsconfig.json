{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "scripts/**/*.ts",
    "contracts/**/*.ts",
    "hardhat.config.cjs"
  ],
  "exclude": [
    "node_modules",
    "artifacts",
    "cache",
    "dist",
    "deployments"
  ]
}

{
  "name": "ticketshield",
  "private": true,
  "version": "1.0.0",
  "description": "TicketShield - Blockchain-based Event Ticketing System",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "test:frontend": "npm run test --prefix frontend",
    "test:backend": "npm run test --prefix backend",
    "compile": "npm run compile --prefix backend",
    "deploy": "npm run deploy --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "ethers": "^6.16.0",
    "firebase": "^12.10.0",
    "jsonwebtoken": "^9.0.3"
  }
}
